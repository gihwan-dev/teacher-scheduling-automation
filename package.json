{
  "name": "scheduling-automation",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:diagnose": "vitest run --config vitest.config.ts --reporter=default --reporter=hanging-process",
    "test:acceptance": "vitest run --config vitest.config.ts src/features/release-gate/lib/__tests__/phase7-acceptance.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "release:gate": "pnpm run typecheck && pnpm run lint src && pnpm run test:acceptance && pnpm run test:unit",
    "format": "prettier",
    "check": "prettier --write . && eslint --fix"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/geist": "^5.2.8",
